---
import FooterLinks from "./FooterLinks";
---

<footer
  class="text-center bottom-0 mt-auto w-full flex flex-col justify-center gap-y-4 py-10 px-4 bg-grid-animated [--grid-size:26px] [--grid-color:rgba(0,0,0,0.06)] dark:[--grid-color:rgba(255,255,255,0.08)] dark:text-gray-100"
>
  <div class="font-pixel uppercase text-xs sm:text-sm flex flex-col items-center gap-1">
    <span>~ Made with a secret sauce ~</span>
    <div class="flex flex-wrap justify-center gap-x-3">
      <a
        href="https://github.com/purduehackers/blog"
        target="_blank"
        class="text-amber-500 hover:text-amber-400 transition"
      >
        Open source
      </a>
      <span>|</span>
      <a
        href="https://vercel.com?utm_source=purdue-hackers&utm_campaign=oss"
        target="_blank"
        class="text-amber-500 hover:text-amber-400 transition"
      >
        Powered by ▲ Vercel
      </a>
      <span>| © 2026</span>
    </div>
  </div>
  <FooterLinks />
